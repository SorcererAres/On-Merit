# 复制为 .env（.env 已 gitignore，key 只入 env，绝不入代码/库）。
# uvicorn 不自动读 .env；用时 `export $(grep -v '^#' .env | xargs)` 或直接 export。

# —— DeepSeek（推荐：便宜+强+中文，base_url 已内置）——
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat      # 可选覆盖（默认 deepseek-chat；deepseek-reasoner 更强更慢）

# —— 通用 OpenAI 兼容（通义/GLM/OpenAI/Kimi，换 base_url+model 即可）——
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # 通义
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=qwen-max

# —— 本地兜底（免费、慢，无需 key）——
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma4:latest        # 或 gemma4:31b（更强更慢）
