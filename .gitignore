# 上游 clone 已归档为 tar.gz（体积大、可从 GitHub 重新获取，不入库）
# Kami: github.com/tw93/Kami   hiring-agent: github.com/interviewstreet/hiring-agent
*.tar.gz
Kami/
hiring-agent/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 生成/临时产物（渲染产物不入库）
*.pdf
*.html
# 但这些 html 是源文件，必须入库
!resume_agent/assets/templates/*.html
!resume_agent/webapp/frontend/index.html
smoke_out.*
scratchpad/

# 预览配置（含机器/会话相关路径，不入库）
.claude/launch.json

# Claude Code 安装的技能：内容由 skills-lock.json 按哈希锁定，可重装，不入库（类比 node_modules）
.agents/
.claude/skills/

# 密钥（.env 只入本地，绝不入库；.env.example 是占位模板，要入库）
.env
!.env.example

# 简历持久化数据库（本地数据，不入库）
resume_agent/webapp/data/

# 前端 node 依赖与构建产物
node_modules/
resume_agent/webapp/frontend/node_modules/
resume_agent/webapp/static/assets/

# 系统
.DS_Store

# TS 构建缓存
*.tsbuildinfo
